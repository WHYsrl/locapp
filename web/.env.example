# Base URL of the VenueScout backend (Fastify). The client calls `${NEXT_PUBLIC_API_URL}/api/v1/...`
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google SSO (optional): when set, the /login page shows the official Google button.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Google Maps (optional): when set at build time, interactive maps use Google Maps
# instead of MapLibre/OSM.
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIza...
