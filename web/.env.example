# Base URL of the VenueScout backend (Fastify). The client calls `${NEXT_PUBLIC_API_URL}/api/v1/...`
NEXT_PUBLIC_API_URL=http://localhost:4000

# Set to 1 to force demo mode (fixture data, no backend / login required).
# Even when unset, the app falls back to demo mode automatically if the API is unreachable.
NEXT_PUBLIC_DEMO=0
