PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/venuescout
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=change-me-in-production
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_BUCKET=venuescout-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Google SSO: comma-separated OAuth client IDs (web + iOS). Unset → POST /auth/google returns 503
GOOGLE_CLIENT_IDS=
# Comma-separated email domains auto-provisioned as editor via Google SSO (e.g. justwhy.it)
GOOGLE_ALLOWED_DOMAINS=
# Google Maps Platform key (Geocoding + Routes + Static Maps). Unset → OSM Nominatim / tiles / haversine
GOOGLE_MAPS_API_KEY=
# Absolute public base URL of this API, used for public image links (map thumbs) in Slides exports.
# Optional: on Render it falls back to RENDER_EXTERNAL_URL automatically
PUBLIC_API_URL=
# Set to true only if the app should boot even when migrations cannot reach the DB
SKIP_MIGRATE_ON_FAIL=false
AI_DECK_MODEL=claude-opus-4-8  # modello per i testi delle presentazioni (default)
